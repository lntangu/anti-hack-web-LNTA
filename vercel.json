{
  "github": { "silent": true },
  "rewrites": [
    { "source": "/api/stats", "destination": "/api/stats" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self';" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [],
  "images": { "sizes": [256, 384] }
}
